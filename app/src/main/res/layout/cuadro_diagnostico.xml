<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EAEAEA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtMotivoCita"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Dolor abdominal severo"
            android:textStyle="bold"
            android:textColor="#212121"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/txtDoctorYFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Dr. Andrés Gómez • 10 Oct, 2026"
            android:textColor="#00695C"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diagnóstico Clínico:"
            android:textStyle="bold"
            android:textColor="#757575"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/txtDiagnosticoClinico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Gastritis aguda por estrés."
            android:textColor="#424242"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tratamiento:"
            android:textStyle="bold"
            android:textColor="#757575"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/txtTratamiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Omeprazol 20mg en ayunas por 14 días."
            android:textColor="#424242"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sugerencias:"
            android:textStyle="bold"
            android:textColor="#757575"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/txtSugerencias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Evitar comidas picantes, café y alcohol. Masticar despacio."
            android:textColor="#424242"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>