<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EAEAEA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtTituloDiagnostico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Infección Respiratoria Aguda"
            android:textStyle="bold"
            android:textColor="#212121"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/txtDoctorYFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dr. Andrés Gómez • 10 Oct, 2026"
            android:textColor="#00695C"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recomendaciones:"
            android:textStyle="bold"
            android:textColor="#757575"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/txtRecomendaciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar reposo por 3 días. Mantenerse hidratado y evitar cambios bruscos de temperatura."
            android:textColor="#424242"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medicamentos:"
            android:textStyle="bold"
            android:textColor="#757575"
            android:textSize="12sp"/>

        <LinearLayout
            android:id="@+id/layoutMedicamentos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>