<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingEnd="16dp"
        android:paddingVertical="16dp">

        <View
            android:id="@+id/indicadorColor"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#00695C"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtHoraCita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="09:00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/indicadorColor" />

        <TextView
            android:id="@+id/txtAmPmCita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AM"
            android:textSize="12sp"
            android:textColor="#757575"
            app:layout_constraintTop_toBottomOf="@id/txtHoraCita"
            app:layout_constraintStart_toStartOf="@id/txtHoraCita"
            app:layout_constraintEnd_toEndOf="@id/txtHoraCita"/>

        <View
            android:id="@+id/divisorVertical"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:background="#E0E0E0"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/txtHoraCita" />

        <TextView
            android:id="@+id/txtNombrePaciente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ana María González"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/divisorVertical"
            app:layout_constraintEnd_toStartOf="@id/cardEstado" />

        <TextView
            android:id="@+id/txtMotivoCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Control Post-operatorio"
            android:textSize="14sp"
            android:textColor="#5F6368"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/txtNombrePaciente"
            app:layout_constraintStart_toStartOf="@id/txtNombrePaciente"
            app:layout_constraintEnd_toEndOf="@id/txtNombrePaciente" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginEnd="12dp"
            app:cardBackgroundColor="#B2EBF2"
            app:layout_constraintEnd_toStartOf="@id/imgFlechaDer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/txtEstadoCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En espera"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#006064"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"/>
        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/imgFlechaDer"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_media_next"
            app:tint="#9E9E9E"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>