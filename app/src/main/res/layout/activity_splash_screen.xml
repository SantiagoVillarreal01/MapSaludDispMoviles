<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".SplashScreen">

    <!-- Background Blur Circles -->
    <View
        android:id="@+id/topGlow"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/splash_glow_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:alpha="0.2"
        android:translationX="-80dp"
        android:translationY="-80dp"/>

    <View
        android:id="@+id/bottomGlow"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/splash_glow_tertiary"
        app:layout_constraintBottom_toBottomOf="parent"
        android:alpha="0.35"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="80dp"
        android:translationY="80dp"/>

    <!-- Main Container -->
    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="32dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/login_logo_background"
                android:elevation="8dp">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:src="@drawable/logo" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/map_salud"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:textSize="28sp"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Card Image -->
        <FrameLayout
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginTop="90dp"
            android:clipToOutline="true"
            android:background="@drawable/splash_card_background"
            android:elevation="12dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:alpha="0.8"
                android:src="@drawable/medical_map"/>

            <!-- Top Chip -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/splash_gradient_overlay" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:background="@drawable/splash_chip_background"
                android:layout_margin="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="?attr/colorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cerca de ti"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="13sp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- Bottom Chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:background="@drawable/splash_support_chip"
                android:layout_gravity="bottom|end"
                android:layout_margin="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    app:tint="@color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24/7 Soporte"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encuentra atención médica cerca de ti"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="40dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:text="Tu salud no puede esperar. Localiza los mejores centros médicos en tiempo real."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:alpha="0.8"/>

        <!-- Progress Bar -->
        <ProgressBar
            android:layout_width="220dp"
            android:layout_height="8dp"
            android:layout_marginTop="36dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true"
            android:indeterminateTint="?attr/colorPrimary"
            android:progressBackgroundTint="?attr/colorSurfaceVariant"/>

        <!-- Loading Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SINCRONIZANDO UBICACIÓN..."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>