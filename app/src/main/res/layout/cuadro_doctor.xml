<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutline">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgDoctor"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/user"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtNombreDoctor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Dr. Andrés Gómez"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/imgDoctor"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtEspecialidadDoctor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Cardiología"
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="@id/txtNombreDoctor"
            app:layout_constraintTop_toBottomOf="@id/txtNombreDoctor"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtExperiencia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="💼 15 años de experiencia"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="6dp"
            app:layout_constraintStart_toStartOf="@id/txtNombreDoctor"
            app:layout_constraintTop_toBottomOf="@id/txtEspecialidadDoctor"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/dividerLine"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/txtExperiencia" />

        <TextView
            android:id="@+id/txtDisponibilidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 Disponible hoy"
            android:textSize="13sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnReservar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnReservar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReservar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reservar"
            android:textAllCaps="false"
            android:backgroundTint="?attr/colorPrimary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="20dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerLine"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>