<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnRegresar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#00695C" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalles de la Cita"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#00695C"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnGuardarEstado">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <TextView
                        android:id="@+id/txtNombreDetalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre del Paciente"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toca actualizar el estado de esta cita una vez finalizada la consulta."
                        android:textSize="14sp"
                        android:textColor="#5F6368"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Título de Sección -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actualizar Estado"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"/>

            <RadioGroup
                android:id="@+id/radioGroupEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioAtendida"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Atendida / Completada"
                    android:textSize="16sp"
                    android:textColor="#212121"
                    app:buttonTint="#00695C"
                    android:paddingStart="8dp"/>

                <RadioButton
                    android:id="@+id/radioInasistencia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Inasistencia del paciente"
                    android:textSize="16sp"
                    android:textColor="#212121"
                    app:buttonTint="#F57C00"
                    android:layout_marginTop="12dp"
                    android:paddingStart="8dp"/>

                <RadioButton
                    android:id="@+id/radioCancelada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cita cancelada"
                    android:textSize="16sp"
                    android:textColor="#212121"
                    app:buttonTint="#D32F2F"
                    android:layout_marginTop="12dp"
                    android:paddingStart="8dp"/>
            </RadioGroup>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuardarEstado"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="Guardar Cambios"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        android:backgroundTint="#00695C"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>