<?xml version="1.0" encoding="utf-8"?>
<!--
    Fondo tipo "pill" azul suave para badges de estado informativo/pendiente
    (ej: txtEstadoDetalle "Pendiente" en medic_detalle_cita.xml).
    NOTA: si tu Kotlin cambia el color de este TextView en runtime
    según el estado (Pendiente/Atendida/Cancelada) con
    setBackgroundColor(), perderás la forma de pill. Usa
    setBackgroundResource(R.drawable.chip_info_soft / chip_primary_soft /
    chip_danger_soft) en su lugar para mantener el estilo.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#B2EBF2" />
    <corners android:radius="20dp" />
</shape>
